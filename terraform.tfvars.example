# Plantilla de variables. Cópiala a terraform.tfvars y rellena tus valores:
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars está en .gitignore: NO se sube al repositorio porque
# puede contener datos sensibles (como tu IP pública).

# --- General ---
aws_region   = "us-east-1"
environment  = "dev"
project_name = "mi-proyecto"

# --- Backend de estado (los nombres deben coincidir con providers.tf) ---
state_bucket_name = "nombre-bucket-s3-unico-global"
state_table_name  = "nombre-tabla-dynamodb-locks"

# --- Red ---
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# --- Cómputo ---
instance_type = "t3.micro"

# IMPORTANTE: tu IP pública con /32. Nunca uses 0.0.0.0/0 (abriría el SSH al mundo).
# Para averiguar tu IP pública:  curl ifconfig.me
ssh_allowed_cidr = "TU.IP.PUBLICA/32"
